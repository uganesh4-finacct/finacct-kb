# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only: required for seeds, deploy scripts, and admin actions
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Deploy migrations (one of the following):
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# SUPABASE_DB_PASSWORD=your_database_password
# SUPABASE_ACCESS_TOKEN=your_supabase_personal_access_token

# App Configuration
# Used as the base URL for invite links (set to https://kb.finacct360.io in production).
# In Supabase Dashboard → Auth → URL Configuration, add to Redirect URLs: {{NEXT_PUBLIC_APP_URL}}/auth/accept-invite
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Certificate email (optional – for "Email certificate to me" on certificate page)
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxx
# From address (must use a verified domain in Resend, e.g. academy@finacct360.io)
RESEND_FROM=FinAcct360 Academy <academy@finacct360.io>
